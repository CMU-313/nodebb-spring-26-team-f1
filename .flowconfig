.*loader\.js
.*eslint\.config\.mjs
.*webpack\..*\.js
.*require-main\.js
.*app\.js
.*src/als\.js
.*src/analytics\.js
.*src/batch\.js
.*src/cache\.js
.*src/constants\.js
.*src/coverPhoto\.js
.*src/emailer\.js
.*src/events\.js
.*src/file\.js
.*src/flags\.js
.*src/helpers\.js
.*src/image\.js
.*src/install\.js
.*src/languages\.js
.*src/logger\.js
.*src/notifications\.js
.*src/pagination\.js
.*src/password\.js
.*src/password_worker\.js
.*src/prestart\.js
.*src/promisify\.js
.*src/pubsub\.js
.*src/request\.js
.*src/search\.js
.*src/settings\.js
.*src/sitemap\.js
.*src/slugify\.js
.*src/social\.js
.*src/start\.js
.*src/translator\.js
.*src/upgrade\.js
.*src/utils\.js
.*src/webserver\.js

[include]

[libs]

[lints]
untyped-type-import=error
internal-type=error
unsafe-object-assign=error
nested-component=error
nested-hook=error
libdef-override=error
deprecated-type-bool=error

[options]
all=true

[strict]

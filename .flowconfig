.*/src/socket\.io/.*
.*/src/cli/.*
.*/src/meta/.*
.*/src/admin/.*
.*/src/messaging/.*
.*/src/navigation/.*
.*/src/plugins/.*
.*/src/rewards/.*
.*/src/widgets/.*
.*/src/cache/.*
.*/\.docker/.*
.*/\.devcontainer/.*
.*/\.github/.*
.*/\.tx/.*
.*/types/.*

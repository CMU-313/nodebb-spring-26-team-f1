.*/__tests__/.*
.*/build/.*
.*/install/.*
.*/scripts/.*
.*/src/views/.*
.*/src/upgrades/.*
.*/src/activitypub/.*
.*/src/controllers/.*
.*/src/database/.*
.*/src/middleware/.*
